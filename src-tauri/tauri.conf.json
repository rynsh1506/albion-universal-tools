{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Avalonian Tools",
  "version": "1.1.2",
  "identifier": "com.xamnes.avalonian-tools",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Avalonian Tools",
        "label": "main",
        "width": 1400,
        "height": 800,
        "resizable": true,
        "fullscreen": false,
        "maximized": false,
        "minWidth": 1000,
        "minHeight": 700,
        "decorations": true,
        "center": true,
        "visible": false
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": [
          "$APPDATA/item_images/**",
          "$APP_DATA/item_images/**",
          "$APP_LOCAL_DATA/item_images/**",
          "$APP_CONFIG/item_images/**"
        ]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
